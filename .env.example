# Nautikalpanel Environment Variables
# Copy this file to .env and modify as needed

RUST_LOG=INFO
# Server Configuration
NAUTIKAL__SERVER__HOST=127.0.0.1
NAUTIKAL__SERVER__PORT=9090

# Kubernetes Configuration
NAUTIKAL__KUBERNETES__NAMESPACE=nautikal
NAUTIKAL__KUBERNETES__DEFAULT_STORAGE_CLASS=longhorn

# Database Configuration
NAUTIKAL__DATABASE__PATH=./db
NAUTIKAL__DATABASE__NAMESPACE=nautikal
NAUTIKAL__DATABASE__NAME=nautikal

# Paths Configuration
NAUTIKAL__PATHS__K8S_TEMPLATES=k8s-templates
NAUTIKAL__PATHS__GAME_SERVER_TEMPLATES=game-server-templates
NAUTIKAL__PATHS__FRONTEND=frontend
# Optional: Extra directory for custom K8s templates
# NAUTIKAL__PATHS__EXTRA_K8S_TEMPLATES=custom-k8s-templates
